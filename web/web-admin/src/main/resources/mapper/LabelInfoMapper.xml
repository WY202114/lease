<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wzc.lease.web.admin.mapper.LabelInfoMapper">

    <select id="selectListByApartmentId" resultType="com.wzc.lease.model.entity.LabelInfo">
        <!--
            【外层查询 - 主表 label_info】
            根据内层查出的标签 ID 列表，从主表中查询标签的详细信息（名称、类型）
            公寓与标签是多对多关系，需要通过中间表 apartment_label 来关联
        -->
        select id,
               type,
               name
        from label_info
        where is_deleted = 0
        <!--
        逻辑删除：
        is_deleted = 0：表示只查询未被逻辑删除的标签（0 表示未删除）。
        is_deleted = 1：表示已逻辑删除的标签（1 表示已删除）。
        -->
          and id in (
              <!--
                  【内层子查询 - 中间表 apartment_label】
                  先从中间表查出"该公寓关联了哪些标签的 ID"
                  例如公寓 ID=1 关联了标签 [1, 3, 5]，则返回这组 label_id
              -->
              select label_id
              from apartment_label
              where is_deleted = 0
                and apartment_id = #{id})

    </select>
</mapper>
